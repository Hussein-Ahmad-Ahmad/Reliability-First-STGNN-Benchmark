# Normalize line endings to LF for all text files stored in the repository
* text=auto eol=lf

# Force LF for these specific files regardless of OS
*.py      text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf
LICENSE   text eol=lf

# Binary files — do not touch line endings
*.npy     binary
*.npz     binary
*.pkl     binary
*.pt      binary
*.pth     binary
*.png     binary
*.jpg     binary
*.pdf     binary
